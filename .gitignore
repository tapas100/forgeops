# =============================================================================
# ForgeOps Platform — .gitignore
# =============================================================================

# ── Secrets & credentials (NEVER commit these) ────────────────────────────────
*.env
*.env.*
!*.env.example
.env.local
secrets/
credentials/
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Jenkins home (runtime state — use persistent volume) ─────────────────────
jenkins_home/
/opt/forgeops/

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# ── Test output ───────────────────────────────────────────────────────────────
reports/
coverage/
junit.xml
*.lcov

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.tar.gz
*.zip

# ── IDE & OS files ────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Podman / container state ─────────────────────────────────────────────────
/opt/forgeops/state/

# ── SSL certs (managed by certbot — not stored in repo) ─────────────────────
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt
!nginx/ssl/.gitkeep
