{
  "name": "node-worker",
  "version": "1.0.0",
  "description": "ForgeOps sample Node.js background worker",
  "main": "src/worker.js",
  "scripts": {
    "start":    "node src/worker.js",
    "test":     "jest --coverage --forceExit",
    "test:ci":  "jest --ci --coverage --forceExit --detectOpenHandles",
    "lint":     "eslint src tests --ext .js",
    "lint:fix": "eslint src tests --ext .js --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint":     "^8.57.0",
    "jest":       "^29.7.0",
    "jest-junit": "^16.0.0"
  },
  "jest": {
    "testEnvironment":    "node",
    "testMatch":          ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageReporters":  ["text", "lcov", "json-summary"],
    "reporters": [
      "default",
      ["jest-junit", {
        "outputDirectory": ".",
        "outputName":      "junit.xml",
        "suiteName":       "node-worker unit tests"
      }]
    ]
  },
  "eslintConfig": {
    "env":     { "node": true, "es2022": true, "jest": true },
    "extends": ["eslint:recommended"],
    "rules": {
      "no-console":     "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "semi":           ["error", "always"]
    }
  }
}
